  "item": [
    {
      "name": "Email incorreto e senha correta",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 401\", function () {\r",
              "    pm.response.to.have.status(401);\r",
              "    });\r",
              "pm.test(\"Mensagem de unthorized\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"Email e/ou senha inválidos\");\r",
              "    });\r",
              "pm.test(\"Token não é retornado\", function () {\r",
              "        pm.expect(pm.response.json().token).to.be.undefined;\r",
              "        });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "token",
            "value": "",
            "type": "text",
            "disabled": true
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"email\": \"fulana123@qa.com\",\r\n  \"password\": \"{{password}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}login",
          "host": [
            "{{url}}login"
          ]
        }
      },
      "response": []
    },
